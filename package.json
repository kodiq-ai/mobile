{
  "name": "kodiq-academy",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "clean": "cd android && ./gradlew clean && cd ..",
    "pod-install": "cd ios && pod install && cd ..",
    "lint": "eslint .",
    "format": "prettier --write '**/*.{ts,tsx,js,json}'",
    "prepare": "husky"
  },
  "dependencies": {
    "@invertase/react-native-apple-authentication": "^2.5.1",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-community/netinfo": "^11.4.0",
    "@react-native-firebase/analytics": "^23.8.6",
    "@react-native-firebase/app": "^23.8.6",
    "@react-native-firebase/crashlytics": "^23.8.6",
    "@react-native-firebase/messaging": "^23.8.6",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@sentry/react-native": "^8.2.0",
    "@supabase/supabase-js": "^2.95.3",
    "posthog-react-native": "^4.36.1",
    "prop-types": "^15.8.1",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-haptic-feedback": "^2.3.3",
    "react-native-keychain": "^10.0.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-svg": "^15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-webview": "^13.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/react": "^19.2.0",
    "typescript": "^5.8.3",
    "@react-native/eslint-config": "0.84.1",
    "eslint": "^8.19.0",
    "prettier": "2.8.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "packageManager": "pnpm@10.4.1"
}
